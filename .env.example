# =============================================================================
# Outreach — environment variables
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in each value below (NEVER paste real keys into Cursor chat).
#   3. For production, paste the same names into Render/Vercel env-var settings.
#
# LOCAL DEV:  SPRING_PROFILES_ACTIVE=dev  (most AI/storage/email vars optional)
# PRODUCTION: SPRING_PROFILES_ACTIVE=prod (StartupValidator enforces more vars)
# =============================================================================


# ── Runtime profile ──────────────────────────────────────────────────────────
# What it's for: selects dev vs prod Spring config (security, Hikari pool, cookies)
# Where to get it: set manually — use "dev" locally, "prod" on Render
SPRING_PROFILES_ACTIVE=dev

# Render sets this automatically — leave 8080 for local dev
# Where to get it: Render injects PORT; local default is 8080
PORT=8080


# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# What it's for: PostgreSQL connection for all app data (users, apps, scores, …)
# Where to get it: https://supabase.com/dashboard → your project → Connect → Connection string
#   IMPORTANT: use the **Transaction pooler** URI (port 6543), NOT the direct/session pooler.
#   Format for Spring JDBC:
#     DATABASE_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
#   Username is usually: postgres.YOUR_PROJECT_REF
#   Password is the database password you set when creating the project.
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# Optional: tune Hikari pool for Supabase free tier (prod default 8)
HIKARI_MAX_POOL=8
HIKARI_MIN_IDLE=2


# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# What it's for: rate limits, token budgets, session cache, job counters, digest dedup
# Where to get it: https://console.upstash.com → Create database → REST or Redis tab
#   REDIS_HOST  = the hostname (e.g. xxx-xxx.upstash.io)
#   REDIS_PORT  = usually 6379
#   REDIS_PASSWORD = the password shown on the database details page (required for Upstash)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=


# ── Security (JWT + cookies + CORS) ──────────────────────────────────────────
# What it's for: signs access tokens; must be ≥32 random chars. Generate locally:
#   openssl rand -base64 48
# Where to get it: generate yourself — NEVER reuse the example below
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48

# Prod: must be true (StartupValidator checks this when profile=prod)
# Where to get it: set manually — false for local HTTP, true for HTTPS production
COOKIE_SECURE=false

# Comma-separated frontend origins allowed to call the API (include credentials/cookies)
# Where to get it: your Vercel URL, e.g. https://your-app.vercel.app
#   Local dev: http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Backend uses this for email links and OAuth redirect base
# Where to get it: same as your Vercel frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:3000


# ── Frontend (Next.js — also set in Vercel) ──────────────────────────────────
# What it's for: browser calls to the backend API
# Where to get it: your Render backend URL + /api/v1, e.g. https://outreach-api.onrender.com/api/v1
#   Local dev: http://localhost:8080/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Optional: frontend error tracking (no-op if blank)
# Where to get it: https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=


# ── File storage (Cloudflare R2) ─────────────────────────────────────────────
# What it's for: resume PDF storage in production (local ./storage used when blank)
# Where to get it: https://dash.cloudflare.com → R2 → Manage R2 API Tokens → Create token
#   R2_ACCOUNT_ID  = Cloudflare Account ID (Overview page, right sidebar)
#   R2_ACCESS_KEY  = Access Key ID from the token
#   R2_SECRET_KEY  = Secret Access Key from the token
#   R2_BUCKET      = bucket name you create under R2 → Create bucket
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# Local-only fallback when R2 vars are blank
STORAGE_LOCAL_PATH=./storage


# ── Email (Resend) ───────────────────────────────────────────────────────────
# What it's for: verification emails, password reset, notifications
# Where to get it: https://resend.com/api-keys → Create API Key
RESEND_API_KEY=

# Sender address — must be a verified domain in Resend, or use onboarding@resend.dev for testing
# Where to get it: Resend → Domains → add your domain, or use onboarding@resend.dev
RESEND_FROM=onboarding@resend.dev


# ── AI providers (at least one required in prod) ─────────────────────────────
# What it's for: resume analysis, email parsing, score insights
# Where to get Gemini: https://aistudio.google.com/apikey → Create API key
GEMINI_API_KEY=

# Where to get Groq: https://console.groq.com/keys → Create API Key
GROQ_API_KEY=


# ── OAuth (Google + GitHub) ──────────────────────────────────────────────────
# What it's for: "Sign in with Google/GitHub" buttons
# Where to get Google: https://console.cloud.google.com/apis/credentials
#   → Create OAuth 2.0 Client ID → Web application
#   Authorized redirect URI: https://YOUR-RENDER-URL/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where to get GitHub: https://github.com/settings/developers → OAuth Apps → New
#   Authorization callback URL: https://YOUR-RENDER-URL/login/oauth2/code/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# ── Payments (Razorpay — use TEST keys first) ────────────────────────────────
# What it's for: Season Pass / subscription checkout
# Where to get it: https://dashboard.razorpay.com/app/keys → Generate Test Key
#   (Live keys require KYC — stay on Test mode until launch)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook secret: Razorpay → Settings → Webhooks → create endpoint → copy secret
#   Webhook URL: https://YOUR-RENDER-URL/api/v1/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=

# Plan IDs: create subscription plans in Razorpay Dashboard → Subscriptions → Plans
RAZORPAY_PLAN_ID_MONTHLY=
RAZORPAY_PLAN_ID_ANNUAL=

# Display prices (INR) — defaults shown if unset
PRICE_SEASON_PASS_INR=499
PRICE_MONTHLY_INR=199
PRICE_ANNUAL_INR=1499


# ── Inbound email forwarding ─────────────────────────────────────────────────
# What it's for: verifies webhook calls when Resend/inbound provider forwards job emails
# Where to get it: generate yourself — openssl rand -hex 32
INBOUND_WEBHOOK_SECRET=

# Domain suffix for user forwarding addresses (e.g. user-token@track.yourdomain.com)
# Where to get it: your domain DNS — configure after Resend inbound is set up
INBOUND_EMAIL_DOMAIN=track.outreachos.com


# ── Observability (optional) ─────────────────────────────────────────────────
# What it's for: backend error tracking in production
# Where to get it: https://sentry.io → Project Settings → DSN (Java/Spring)
SENTRY_DSN=
