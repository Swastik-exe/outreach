# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Spring Boot
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Environment — NEVER commit real secrets
.env

# Local file storage (dev-only fallback for uploaded resumes — runtime data, not source)
# Leading slash matters: anchors to repo root only, so it does NOT match
# src/main/java/com/outreach/resume/storage/ (the actual Java package).
/storage/

# IDE
.idea/
*.iml
*.iws
.classpath
.project
.settings/
*.eclipse
.vscode/
*.code-workspace

# OS
.DS_Store
Thumbs.db
*.swp
*~

# Logs
*.log
logs/
spring.log

# Local commit helpers (Cursor/PowerShell workarounds — never commit)
.commit-msg*.txt
.do-commit*.sh
.tmp-*

# JVM crash logs
hs_err_pid*
replay_pid*
