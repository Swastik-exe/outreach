# Frontend-only env vars (also copy to Vercel → Settings → Environment Variables)
# See repo root .env.example for the full list.

# Backend API base URL (browser-visible — not a secret)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Optional: Sentry browser DSN (no-op if blank)
NEXT_PUBLIC_SENTRY_DSN=
